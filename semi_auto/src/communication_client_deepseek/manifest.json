{
  "manifest_version": 3,
  "name": "DeepSeek Communication Client",
  "version": "1.0",
  "description": "Communicates with a local server to process interactions using DeepSeek.",
  "permissions": [
    "alarms",
    "storage"
  ],
  "host_permissions": [
    "http://localhost:8080/*",
    "*://chat.deepseek.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["*://chat.deepseek.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}

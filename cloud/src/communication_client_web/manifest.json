{
  "manifest_version": 3,
  "name": "LLM Communication Client",
  "version": "1.0",
  "description": "Communicates with a local server to process interactions using AI web UIs.",
  "permissions": [
    "alarms",
    "storage"
  ],
  "host_permissions": [
    "http://localhost:9223/*",
    "*://*/*"
  ],
  "action": {
    "default_title": "Toggle LLM Client"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "*://chat.deepseek.com/*",
        "*://chatgpt.com/*",
        "*://claude.ai/*",
        "*://*.qwen.ai/*"
      ],
      "js": ["adapters.js", "content.js"],
      "run_at": "document_idle"
    }
  ]
}
